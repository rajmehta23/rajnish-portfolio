# GEMINI_API_KEY: Required for generating content via the API.
# The host infrastructure automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# The host infrastructure automatically injects this at runtime with the service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
# Resend API Key for sending emails from the contact form
RESEND_API_KEY=
